# =============================================================
# .GITIGNORE — Terraform
# Archivos que NO deben subirse a GitHub
# =============================================================

# -------------------------------------------------------
# CREDENCIALES — NUNCA subir al repositorio
# -------------------------------------------------------
terraform.tfvars
*.tfvars
!*.tfvars.example      # sí se permite subir archivos de ejemplo

# -------------------------------------------------------
# ARCHIVOS LOCALES DE TERRAFORM
# -------------------------------------------------------
.terraform/
.terraform.lock.hcl

# -------------------------------------------------------
# STATE — el estado se gestiona en Terraform Cloud
# -------------------------------------------------------
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# -------------------------------------------------------
# LOGS Y ARCHIVOS TEMPORALES
# -------------------------------------------------------
crash.log
crash.*.log
*.tfplan
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -------------------------------------------------------
# SISTEMA OPERATIVO
# -------------------------------------------------------
.DS_Store
Thumbs.db
